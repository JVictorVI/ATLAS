{
  "name": "ATLAS",
  "displayName": "atlas",
  "description": "Assistente Técnico, Lógico e Arquitetural de Software",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atlas-chat-container",
          "title": "ATLAS",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "atlas-chat-container": [
        {
          "type": "webview",
          "id": "atlas-chat.view",
          "name": "Assistente Inteligente"
        }
      ]
    },
    "contributes": {
      "commands": [
        {
          "command": "atlas.quickAnalysis",
          "title": "ATLAS: Análise Rápida do Arquivo Atual",
          "category": "ATLAS"
        }
      ],
      "menus": {
        "editor/title": [
          {
            "command": "atlas.quickAnalysis",
            "group": "navigation"
          }
        ],
        "commandPalette": [
          {
            "command": "atlas.quickAnalysis"
          }
        ]
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.15.1",
    "uuid": "^14.0.0"
  }
}
